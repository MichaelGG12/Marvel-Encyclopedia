@page "{selectedOption}/{id}"
@model MarvelApp.Pages.ViewModel
@{
    ViewData["Title"] = "Hero page";
}

<div class="container">
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3">
        <div class="mx-auto mt-4">
            @if (!string.IsNullOrEmpty(Model.SearchResult.Data.Results[0].Name))
            {
                <h5 class="card-title text-center">@Model.SearchResult.Data.Results[0].Name</h5>
            }
            else if (!string.IsNullOrEmpty(Model.SearchResult.Data.Results[0].Title))
            {
                <h5 class="card-title text-center">@Model.SearchResult.Data.Results[0].Title</h5>
            }
            else
            {
                <h5 class="card-title text-center">@Model.SearchResult.Data.Results[0].FullName</h5>
            }
            <img src="@($"{@Model.SearchResult.Data.Results[0].Thumbnail.Path}.{@Model.SearchResult.Data.Results[0].Thumbnail.Extension}")" class="card-img-top"
                 style="object-fit: cover; height: 300px">
                 
            <h5 class="card-title">Description</h5>
            @if (!string.IsNullOrEmpty(Model.SearchResult.Data.Results[0].Description))
            {
                <p class="card-text">@Model.SearchResult.Data.Results[0].Description</p>
            }
            else
            {
                <p class="card-text">No data available to display</p>
            }

            <h5 class="card-title">Comics</h5>
            
            @if (Model.SearchResult.Data.Results[0].Comics != null)
            {
                @foreach (var comic in Model.SearchResult.Data.Results[0].Comics.Items)
                {
                    <p>@comic.Name</p>
                }
            }
            else
            {
                <p class="card-text">No data available to display</p>
            }
        </div>
    </div>
</div>
